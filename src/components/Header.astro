---
import Logo from './Logo.astro';
---

<header class="header-container">
  <div class="header-white-bar">
    <!-- Brand / Logo -->
    <a href="#" class="brand" aria-label="Volver al inicio">
      <img src="/logorpcatupc2.0.svg" alt="rpc atupc" width="150" height="75" />
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="nav-menu">
      <a href="#" class="nav-link active">Inicio</a>
      <a href="#servicios" class="nav-link">Servicios</a>
      <a href="#nosotros" class="nav-link">Nosotros</a>
      <a href="#contacto" class="nav-link">Contacto</a>
    </nav>

    <!-- Header Actions (Pill Button) -->
    <div class="header-actions">
      <a href="#contacto" class="btn-pill dark header-cta-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        <span>Agendar</span>
      </a>
      
      <!-- Mobile Hamburger Toggle -->
      <button class="mobile-toggle" aria-label="Abrir menú" aria-expanded="false">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Panel -->
  <div class="mobile-nav-panel">
    <nav class="mobile-nav-links">
      <a href="#" class="mobile-link">Inicio</a>
      <a href="#servicios" class="mobile-link">Servicios</a>
      <a href="#nosotros" class="mobile-link">Nosotros</a>
      <a href="#contacto" class="mobile-link">Contacto</a>
      <a href="#contacto" class="btn-pill primary mobile-cta">
        <span>Cotizar por WhatsApp</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .header-container {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 40px);
    max-width: 1260px;
    z-index: 1000;
    transition: var(--transition-smooth);
  }

  .header-white-bar {
    background: var(--accent-white);
    height: 76px;
    border-radius: var(--radius-pill);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px 0 32px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
    position: relative;
    z-index: 1010;
    transition: var(--transition-smooth);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Scrolled header effect */
  :global(.scrolled) .header-white-bar {
    height: 68px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.6);
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
  }

  .brand {
    display: flex;
    align-items: center;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-link {
    color: var(--text-dark);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    position: relative;
    opacity: 0.75;
    padding: 6px 0;
  }

  .nav-link:hover, .nav-link.active {
    opacity: 1;
    color: var(--text-dark);
  }

  /* Dynamic futuristic slide line for links */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--accent-amber);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link:hover::after, .nav-link.active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .header-cta-btn {
    padding: 10px 24px;
    font-size: 0.8rem;
    box-shadow: 0 4px 14px rgba(0,0,0,0.15);
  }

  /* Mobile toggle styles */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 16px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1020;
  }

  .mobile-toggle .bar {
    width: 100%;
    height: 2.5px;
    background-color: var(--text-dark);
    border-radius: var(--radius-pill);
    transition: var(--transition-smooth);
  }

  /* Mobile menu panel */
  .mobile-nav-panel {
    position: absolute;
    top: 38px;
    left: 0;
    right: 0;
    background: var(--bg-matte);
    border: var(--border-subtle);
    border-radius: 30px;
    padding: 60px 24px 30px 24px;
    box-shadow: var(--shadow-glass);
    z-index: 990;
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: var(--transition-smooth);
  }

  .mobile-nav-panel.open {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
  }

  .mobile-link {
    font-family: var(--font-tech);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .mobile-link:hover {
    color: var(--accent-amber);
    text-shadow: 0 0 10px rgba(255, 107, 0, 0.3);
  }

  .mobile-cta {
    width: 100%;
    margin-top: 15px;
    text-align: center;
  }

  /* Responsive media queries */
  @media (max-width: 850px) {
    .nav-menu {
      display: none;
    }
    
    .mobile-toggle {
      display: flex;
    }

    .header-cta-btn {
      display: none; /* Hide on small screen header to save space, show inside mobile panel */
    }

    /* Active hamburger animation */
    .mobile-toggle.active .bar:nth-child(1) {
      transform: translateY(6.5px) rotate(45deg);
    }

    .mobile-toggle.active .bar:nth-child(2) {
      opacity: 0;
      transform: translateX(-10px);
    }

    .mobile-toggle.active .bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }

  @media (max-width: 480px) {
    .header-white-bar {
      padding: 0 16px 0 20px;
    }
    .header-container {
      width: calc(100% - 20px);
      top: 10px;
    }
  }
</style>

<script>
  // Add scrolled class to shrink header
  window.addEventListener('scroll', () => {
    const header = document.querySelector('.header-container');
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  // Mobile Menu Toggle logic
  const toggleBtn = document.querySelector('.mobile-toggle');
  const navPanel = document.querySelector('.mobile-nav-panel');
  const navLinks = document.querySelectorAll('.mobile-link, .mobile-cta');

  if (toggleBtn && navPanel) {
    const toggleMenu = () => {
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      toggleBtn.classList.toggle('active');
      navPanel.classList.toggle('open');
    };

    toggleBtn.addEventListener('click', toggleMenu);

    // Close panel when clicking a link
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        toggleBtn.setAttribute('aria-expanded', 'false');
        toggleBtn.classList.remove('active');
        navPanel.classList.remove('open');
      });
    });
  }

  // Active section indicator in navigation
  const sections = document.querySelectorAll('section[id]');
  const desktopLinks = document.querySelectorAll('.nav-link');

  window.addEventListener('scroll', () => {
    let current = '';
    const scrollPos = window.scrollY + 120; // offset

    sections.forEach(section => {
      const sectionTop = (section as HTMLElement).offsetTop;
      const sectionHeight = section.clientHeight;
      if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
        current = section.getAttribute('id') || '';
      }
    });

    desktopLinks.forEach(link => {
      link.classList.remove('active');
      const href = link.getAttribute('href');
      if (href === '#' && current === '') {
        link.classList.add('active');
      } else if (href === `#${current}`) {
        link.classList.add('active');
      }
    });
  });
</script>
