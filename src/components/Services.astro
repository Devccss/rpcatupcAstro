    tag: "DIAGNÓSTICO INCLUIDO",
    whatsapp: "Hola rpc atupc! Necesito cotizar una *Reparación Técnica* para mi equipo. Me gustaría que me contacten para coordinar.",
  },
  {
    id: "optimizacion",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
    label: "Optimización de Velocidad",
    desc: "Limpieza de sistema, optimización de inicio, actualización de drivers y ajuste fino para máximo rendimiento en Windows.",
    tag: "RENDIMIENTO +200%",
    whatsapp: "Hola rpc atupc! Necesito cotizar una *Optimización de Velocidad* para mi computador. Me gustaría que me contacten.",
  },
  {
    id: "limpieza",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    label: "Mantenimiento y Limpieza",
