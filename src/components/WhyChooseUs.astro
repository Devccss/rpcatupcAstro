---
const perks = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: "Garantía de Trabajo",
    desc: "Todo servicio técnico cuenta con garantía de 30 días sobre la intervención realizada.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: "Respuesta en 24 Horas",
    desc: "Diagnóstico inicial y presupuesto en menos de 24 horas hábiles desde que nos contactas.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: "Precios Transparentes",
    desc: "Sin costos ocultos. Te entregamos un presupuesto detallado antes de cualquier intervención.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: "Técnicos Certificados",
    desc: "Personal altamente capacitado con experiencia comprobada en hardware y software de todos los fabricantes.",
  },
];
---

<section class="why-section" id="nosotros">
  <div class="why-wrapper">

    <!-- Left: big accent block (like white block in reference design) -->
    <div class="why-left accent-panel">
      <div class="why-left-inner">
        <div class="glow-badge dark-badge">
          <span class="dot amber-dot"></span>
          ¿Por qué elegirnos?
        </div>
        <h2 class="why-title">
          Más de 5 años<br/>potenciando<br/>
          <span class="amber-highlight">computadores</span><br/>
          en la región.
        </h2>
        <p class="why-body">
          En <strong>rpc atupc</strong> no solo reparamos equipos, creamos experiencias
          de rendimiento. Cada trabajo es realizado con precisión, cuidado y el
          compromiso de entregarte tu equipo funcionando mejor que nunca.
        </p>
        <a
          href={`https://wa.me/56921987696?text=${encodeURIComponent("Hola rpc atupc! Me gustaría obtener más información sobre sus servicios. ¿Podrían contactarme?")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-pill light-accent why-cta"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.099.546 4.07 1.499 5.786L0 24l6.394-1.679A11.952 11.952 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.013-1.373l-.36-.214-3.732.979.998-3.648-.235-.374A9.818 9.818 0 1 1 12 21.818z"/></svg>
          Hablar con un técnico
        </a>
      </div>
    </div>

    <!-- Right: perks grid -->
    <div class="why-right">
      <div class="perks-grid">
        {perks.map((perk) => (
          <div class="perk-card console-panel interactive">
            <div class="perk-icon">
              <Fragment set:html={perk.icon} />
            </div>
            <div class="perk-content">
              <h3 class="perk-title">{perk.title}</h3>
              <p class="perk-desc">{perk.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .why-section {
    padding: 100px 20px;
    position: relative;
  }

  .why-wrapper {
    max-width: 1260px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: stretch;
  }

  /* Left white accent block */
  .why-left {
    border-radius: var(--radius-extreme);
  }

  .why-left-inner {
    display: flex;
    flex-direction: column;
    gap: 28px;
    height: 100%;
  }

  .dark-badge {
    background: rgba(7, 8, 10, 0.08);
    border-color: rgba(7, 8, 10, 0.15);
    color: var(--text-dark);
  }

  .amber-dot {
    background-color: var(--accent-amber) !important;
    box-shadow: 0 0 8px var(--accent-amber) !important;
  }

  .why-title {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-dark);
    text-transform: uppercase;
  }

  .amber-highlight {
    color: var(--accent-amber);
  }

  .why-body {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(7, 8, 10, 0.65);
    flex: 1;
  }

  .why-body strong {
    color: var(--text-dark);
    font-weight: 700;
  }

  .why-cta {
    align-self: flex-start;
  }

  /* Right perks grid */
  .why-right {
    display: flex;
    align-items: stretch;
  }

  .perks-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    width: 100%;
  }

  .perk-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 28px;
    border-radius: var(--radius-card);
  }

  .perk-icon {
    width: 44px;
    height: 44px;
    color: var(--accent-amber);
    flex-shrink: 0;
  }

  .perk-icon svg {
    width: 100%;
    height: 100%;
  }

  .perk-content {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .perk-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-pure);
    letter-spacing: -0.01em;
  }

  .perk-desc {
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--text-muted);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .why-wrapper {
      grid-template-columns: 1fr;
    }

    .perks-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .perks-grid {
      grid-template-columns: 1fr;
    }

    .why-section {
      padding: 70px 16px;
    }
  }
</style>
