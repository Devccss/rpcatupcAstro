---

<section class="map-section" id="ubicacion">
  <div class="map-wrapper">
    <div class="map-header">
      <div class="glow-badge">
        <span class="dot"></span>
        Ubicación
      </div>
      <h2 class="section-title map-title">Encuéntranos en<br/><span class="title-accent">Concepción</span></h2>
    </div>

    <div class="map-container console-panel">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d52748.98024853889!2d-73.08674005!3d-36.82699975!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9669b5398908548f%3A0x8e84f3f3a4cfb21e!2sConcepc%C3%B3n%2C%20B%C3%ADo%20B%C3%ADo%2C%20Chile!5e0!3m2!1ses!2scl!4v1700000000000!5m2!1ses!2scl"
        width="100%"
        height="100%"
        style="border:0; border-radius: var(--radius-card);"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación de rpc atupc en Concepción, Chile"
      ></iframe>

      <!-- Floating label over map -->
      <div class="map-overlay-label">
        <div class="map-pin-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3" fill="white"/></svg>
          <span>rpc atupc · Concepción, Chile</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .map-section {
    padding: 80px 20px 100px;
    position: relative;
  }

  .map-wrapper {
    max-width: 1260px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .map-header {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
    text-align: center;
  }

  .map-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  }

  .map-container {
    position: relative;
    height: 420px;
    padding: 12px;
    overflow: hidden;
  }

  .map-container iframe {
    display: block;
    filter: grayscale(0.8) contrast(1.1) brightness(0.6);
    transition: filter 0.5s ease;
  }

  .map-container:hover iframe {
    filter: grayscale(0.3) contrast(1) brightness(0.8);
  }

  .map-overlay-label {
    position: absolute;
    bottom: 28px;
    left: 28px;
    z-index: 10;
  }

  .map-pin-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--bg-space);
    color: var(--text-primary);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 10px 18px;
    border-radius: var(--radius-pill);
    font-family: var(--font-tech);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
  }

  .map-pin-badge svg {
    color: var(--accent-amber);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .map-container {
      height: 320px;
      padding: 8px;
    }

    .map-section {
      padding: 60px 16px 80px;
    }
  }
</style>
